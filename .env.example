# Praxis Partners 创业评估工具
# 环境变量配置模板

# Anthropic Claude API Key (用于AI深度分析功能)
# 请前往 https://console.anthropic.com/ 获取API密钥
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ===== Supabase配置 =====
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ===== Stripe支付配置 =====
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
# 后端使用: STRIPE_SECRET_KEY
# 后端使用: STRIPE_WEBHOOK_SECRET

# ===== 微信支付配置（可选）=====
VITE_WECHAT_PAY_ENABLED=false

# ===== 应用配置 =====
VITE_APP_ENV=development
VITE_PAYMENT_MOCK_MODE=true  # 开发模式：true, 生产模式：false

# ===== 分析统计（可选）=====
# VITE_MIXPANEL_TOKEN=your_mixpanel_token

# ！！！重要安全提示：
# - 永远不要将真实的API密钥提交到Git仓库
# - .env文件应该被.gitignore排除
# - 仅在开发环境中使用.env.local文件
# - 生产环境应通过安全的密钥管理系统

# 如何获取API密钥：
# 1. Claude API: https://console.anthropic.com/
# 2. Supabase: https://supabase.com/dashboard
# 3. Stripe: https://dashboard.stripe.com/test/apikeys

# 功能说明：
# - AI深度分析: 使用Claude API生成投资分析
# - 支付系统: Supabase + Stripe/微信支付集成
# - 用户配额: 基于订阅层级的使用限制
